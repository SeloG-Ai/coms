datasource db {
  provider = "mongodb"
  url      = env("DB_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Role {
  createdAt   DateTime              @default(now())
  id          String                @id @default(auto()) @map("_id") @db.ObjectId
  name        String?
  permissions EnumRolePermissions[]
  updatedAt   DateTime              @updatedAt
  users       User[]
}

model Task {
  assignee    String?
  createdAt   DateTime        @default(now())
  description String?
  dueDate     DateTime?
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  project     Project?        @relation(fields: [projectId], references: [id])
  projectId   String?         @db.ObjectId
  status      EnumTaskStatus?
  title       String?
  updatedAt   DateTime        @updatedAt
}

model Project {
  createdAt   DateTime  @default(now())
  description String?
  endDate     DateTime?
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String?
  startDate   DateTime?
  tasks       Task[]
  team        Team?     @relation(fields: [teamId], references: [id])
  teamId      String?   @db.ObjectId
  updatedAt   DateTime  @updatedAt
}

model Team {
  createdAt   DateTime  @default(now())
  description String?
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  lead        String?
  name        String?
  projects    Project[]
  updatedAt   DateTime  @updatedAt
  users       User[]
}

model Announcement {
  audience  EnumAnnouncementAudience?
  content   String?
  createdAt DateTime                  @default(now())
  id        String                    @id @default(auto()) @map("_id") @db.ObjectId
  title     String?
  updatedAt DateTime                  @updatedAt
}

model Reminder {
  content    String?
  createdAt  DateTime  @default(now())
  createdBy  String?
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  remindAt   DateTime?
  targetUser String?
  updatedAt  DateTime  @updatedAt
}

model Leaderboard {
  awardedAt DateTime?
  createdAt DateTime  @default(now())
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  points    Int?
  reason    String?
  updatedAt DateTime  @updatedAt
  user      User?     @relation(fields: [userId], references: [id])
  userId    String?   @db.ObjectId
}

model User {
  createdAt    DateTime      @default(now())
  email        String?       @unique
  firstName    String?
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  isActive     Boolean?
  lastName     String?
  leaderboards Leaderboard[]
  password     String
  role         Role?         @relation(fields: [roleId], references: [id])
  roleId       String?       @db.ObjectId
  roles        Json
  team         Team?         @relation(fields: [teamId], references: [id])
  teamId       String?       @db.ObjectId
  telegramId   String?
  updatedAt    DateTime      @updatedAt
  username     String        @unique
}

enum EnumRolePermissions {
  Option1
}

enum EnumTaskStatus {
  Option1
}

enum EnumAnnouncementAudience {
  Option1
}
